# DeepSeek API（可选，推荐配置，让 AI 写文章而非模板拼接）
DEEPSEEK_API_KEY=

# Claude API（可选，DeepSeek 的备用方案）
ANTHROPIC_API_KEY=

# 微信公众号配置（可选，用于自动发布）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# Unsplash 配图（可选，用于文章自动配图，https://unsplash.com/developers 注册获取）
# 不配置时自动使用 Picsum 免费随机图
UNSPLASH_ACCESS_KEY=

# Server酱通知（可选，用于微信推送通知）
# 注册地址：https://sct.ftqq.com/
SERVERCHAN_KEY=
